# AionDB local quickstart credentials.
#
# These values are only for a loopback-only local evaluation. Replace them
# before exposing the stack outside your machine.

AIONDB_PGWIRE_PORT=5432
AIONDB_BOOTSTRAP_USER=dev
AIONDB_BOOTSTRAP_PASSWORD=dev-password-change-me-1A
AIONDB_STUDIO_PORT=8082
AIONDB_STUDIO_DATABASE_URL=postgres://dev:dev-password-change-me-1A@aiondb:5432/default?sslmode=disable
