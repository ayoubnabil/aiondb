# Copy to /etc/aiondb/aiondb.env and restrict permissions to the service owner.
# Do not commit the real environment file.

AIONDB_STORAGE_BACKEND=durable
AIONDB_STORAGE_DATA_DIR=/var/lib/aiondb/data
AIONDB_PGWIRE_LISTEN_ADDR=127.0.0.1:5432
AIONDB_OBSERVABILITY_BIND=127.0.0.1
AIONDB_OBSERVABILITY_PORT=9187
AIONDB_PGWIRE_TLS_MODE=require

# Required when AIONDB_PGWIRE_TLS_MODE is prefer or require.
# AIONDB_PGWIRE_TLS_CERT_PATH=/etc/aiondb/tls/server.crt
# AIONDB_PGWIRE_TLS_KEY_PATH=/etc/aiondb/tls/server.key
# AIONDB_PGWIRE_TLS_CLIENT_CA_PATH=/etc/aiondb/tls/client-ca.crt

# Development bootstrap only. Prefer ordinary role management after first boot.
# AIONDB_BOOTSTRAP_USER=admin
# AIONDB_BOOTSTRAP_PASSWORD=replace-with-a-long-unique-password

# Local lab override only. Persistent production-like data should live on
# encrypted storage instead.
# AIONDB_ALLOW_UNENCRYPTED_STORAGE=true

# Durability policy. Use "always" for fsync-on-every-commit behavior.
AIONDB_STORAGE_DURABLE_WAL_COMMIT_POLICY=always
