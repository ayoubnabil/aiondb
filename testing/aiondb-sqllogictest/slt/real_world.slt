# ============================================================
# Test: "Est-ce qu'on peut construire une vraie app avec AionDB?"
# Simule un backend SaaS basique: users, products, orders
# ============================================================

# --- Schema creation ---
statement ok
CREATE TABLE users (
    id INT PRIMARY KEY,
    email TEXT NOT NULL UNIQUE,
    name TEXT NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
)

statement ok
CREATE TABLE products (
    id INT PRIMARY KEY,
    name TEXT NOT NULL,
    price REAL NOT NULL CHECK (price > 0),
    stock INT NOT NULL DEFAULT 0
)

statement ok
CREATE TABLE orders (
    id INT PRIMARY KEY,
    user_id INT NOT NULL,
    product_id INT NOT NULL,
    quantity INT NOT NULL CHECK (quantity > 0),
    total REAL NOT NULL
)

statement ok
CREATE INDEX idx_orders_user ON orders (user_id)

statement ok
CREATE INDEX idx_orders_product ON orders (product_id)

# --- Insert data ---
statement ok
INSERT INTO users (id, email, name) VALUES
    (1, 'alice@example.com', 'Alice Martin'),
    (2, 'bob@example.com', 'Bob Dupont'),
    (3, 'carol@example.com', 'Carol Durand')

statement ok
INSERT INTO products VALUES
    (10, 'Widget Pro', 29.99, 100),
    (20, 'Gadget Plus', 49.99, 50),
    (30, 'Super Tool', 99.99, 25)

statement ok
INSERT INTO orders VALUES
    (100, 1, 10, 2, 59.98),
    (101, 1, 20, 1, 49.99),
    (102, 2, 30, 1, 99.99),
    (103, 2, 10, 5, 149.95),
    (104, 3, 20, 3, 149.97)

# --- Basic CRUD ---
query I
SELECT COUNT(*) FROM users
----
3

query I
SELECT COUNT(*) FROM orders
----
5

# Update
statement ok
UPDATE products SET stock = stock - 2 WHERE id = 10

query I
SELECT stock FROM products WHERE id = 10
----
98

# Delete
statement ok
DELETE FROM orders WHERE id = 104

query I
SELECT COUNT(*) FROM orders
----
4

# --- JOINs (the bread and butter of any app) ---
query TTR rowsort
SELECT u.name, p.name, o.total
FROM orders o
JOIN users u ON o.user_id = u.id
JOIN products p ON o.product_id = p.id
----
Alice Martin Gadget Plus 49.99
Alice Martin Widget Pro 59.98
Bob Dupont Super Tool 99.99
Bob Dupont Widget Pro 149.95

# --- Aggregates ---
query TR rowsort
SELECT u.name, SUM(o.total) AS total_spent
FROM users u
JOIN orders o ON o.user_id = u.id
GROUP BY u.name
----
Alice Martin 109.97
Bob Dupont 249.94

# Top spender
query T
SELECT u.name
FROM users u
JOIN orders o ON o.user_id = u.id
GROUP BY u.name
ORDER BY SUM(o.total) DESC
LIMIT 1
----
Bob Dupont

# --- Subqueries ---
query T rowsort
SELECT name FROM users WHERE id IN (SELECT DISTINCT user_id FROM orders)
----
Alice Martin
Bob Dupont

# Users who never ordered
query T
SELECT name FROM users WHERE id NOT IN (SELECT user_id FROM orders)
----
Carol Durand

# --- ON CONFLICT (upsert) ---
statement ok
INSERT INTO users (id, email, name) VALUES (4, 'dave@example.com', 'Dave Moreau')

statement ok
INSERT INTO users (id, email, name) VALUES (4, 'dave-new@example.com', 'Dave Updated') ON CONFLICT (id) DO UPDATE SET name = EXCLUDED.name, email = EXCLUDED.email

query TT
SELECT name, email FROM users WHERE id = 4
----
Dave Updated dave-new@example.com

# --- Window functions ---
query TIR
SELECT u.name, o.id, SUM(o.total) OVER (PARTITION BY u.name ORDER BY o.id) AS running_total
FROM orders o
JOIN users u ON o.user_id = u.id
ORDER BY u.name, o.id
----
Alice Martin 100 59.98
Alice Martin 101 109.97
Bob Dupont 102 99.99
Bob Dupont 103 249.94

# --- CTE ---
query TI rowsort
WITH order_counts AS (
    SELECT user_id, COUNT(*) AS cnt FROM orders GROUP BY user_id
)
SELECT u.name, oc.cnt
FROM order_counts oc
JOIN users u ON u.id = oc.user_id
----
Alice Martin 2
Bob Dupont 2

# --- CASE expression ---
query TT rowsort
SELECT name,
    CASE WHEN price < 30 THEN 'budget'
         WHEN price < 80 THEN 'mid-range'
         ELSE 'premium' END AS tier
FROM products
----
Gadget Plus mid-range
Super Tool premium
Widget Pro budget

# --- Cleanup ---
statement ok
DROP TABLE orders

statement ok
DROP TABLE products

statement ok
DROP TABLE users
